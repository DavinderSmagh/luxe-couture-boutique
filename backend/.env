# === Server Configuration ===
PORT=5000

# === MongoDB (Local) ===
MONGO_URI=mongodb://127.0.0.1:27017/luxecouture

# === Security / JWT (for future authentication) ===
JWT_SECRET=your_super_long_random_secret_change_this_1234567890abcdef

# === Optional - useful during development ===
NODE_ENV=development

# === If you add image upload later (Cloudinary example) ===
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# === If you add email sending later ===
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password